<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Green Interactive Wave Web</title>
    <style>
        /* 기본 스타일 리셋 및 변수 설정 */
        :root {
            --primary-green: #2d6a4f;
            --light-green: #d8f3dc;
            --dark-green: #1b4332;
            --accent-green: #52b788;
            --bg-gradient: linear-gradient(135deg, #1b4332 0%, #081c15 100%);
        }

        * {
            margin: 0;
            padding: 0;
            /* ⚠️ 기존 오류 수정: box-box-sizing을 box-sizing으로 변경 */
            box-sizing: border-box;
        }

        body, html {
            width: 100%;
            height: 100%;
            overflow: hidden;
            font-family: 'Pretendard', -apple-system, BlinkMacSystemFont, system-ui, Roboto, sans-serif;
            background: var(--bg-gradient);
            color: #ffffff;
        }

        /* 인터랙션 Canvas 배경 */
        #interaction-canvas {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 1;
            pointer-events: none; /* 클릭 및 호버 이벤트는 body에서 가로채서 처리 */
        }

        /* 메인 콘텐츠 레이어 */
        .container {
            position: relative;
            z-index: 2;
            width: 100%;
            height: 100%;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            padding: 20px;
            text-align: center;
        }

        .content-box {
            background: rgba(45, 106, 79, 0.2);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            padding: 40px 60px;
            border-radius: 20px;
            border: 1px solid rgba(82, 183, 136, 0.3);
            box-shadow: 0 20px 40px rgba(0,0,0,0.3);
            max-width: 600px;
            width: 100%;
            transition: transform 0.3s ease;
        }

        .content-box:hover {
            transform: translateY(-5px);
        }

        h1 {
            font-size: 2.5rem;
            margin-bottom: 20px;
            color: var(--light-green);
            letter-spacing: -0.5px;
        }

        p {
            font-size: 1.1rem;
            line-height: 1.6;
            color: rgba(255, 255, 255, 0.8);
            margin-bottom: 30px;
        }

        .cta-btn {
            background: var(--accent-green);
            color: var(--dark-green);
            border: none;
            padding: 12px 30px;
            font-size: 1rem;
            font-weight: bold;
            border-radius: 30px;
            cursor: pointer;
            transition: all 0.3s ease;
            box-shadow: 0 4px 15px rgba(82, 183, 136, 0.4);
        }

        .cta-btn:hover {
            background: var(--light-green);
            transform: scale(1.05);
        }

        /* 반응형 모바일 스타일 지정 */
        @media (max-width: 768px) {
            .content-box {
                padding: 30px 20px;
            }
            h1 {
                font-size: 1.8rem;
            }
            p {
                font-size: 0.95rem;
            }
        }
    </style>
</head>
<body>

    <!-- 파동 및 퐁당 이펙트가 그려질 캔버스 -->
    <canvas id="interaction-canvas"></canvas>

    <!-- 인터페이스 레이어 -->
    <div class="container">
        <div class="content-box">
            <h1>Green Horizon</h1>
            <p>마우스를 움직여 표면에 파동을 일으켜 보세요.<br>화면을 클릭하면 깊숙이 퐁당 빠지는 인터랙션을 경험할 수 있습니다.</p>
            <button class="cta-btn">자세히 보기</button>
        </div>
    </div>

    <script>
        const canvas = document.getElementById('interaction-canvas');
        const ctx = canvas.getContext('2d');

        // 반응형 화면 크기 설정
        function resizeCanvas() {
            canvas.width = window.innerWidth;
            canvas.height = window.innerHeight;
        }
        window.addEventListener('resize', resizeCanvas);
        resizeCanvas();

        // 마우스 및 터치 상태 관리
        const pointer = { x: null, y: null, isHovering: false };
        const ripples = [];
        const waves = [];

        // 1. 호버 파동(Wave) 클래스 정의
        class HoverWave {
            constructor(x, y) {
                this.x = x;
                this.y = y;
                this.radius = 0;
                this.maxRadius = Math.random() * 40 + 30;
                this.alpha = 0.4;
                this.speed = Math.random() * 1 + 1;
            }
            update() {
                this.radius += this.speed;
                this.alpha = 1 - (this.radius / this.maxRadius);
            }
            draw() {
                ctx.beginPath();
                ctx.arc(this.x, this.y, this.radius, 0, Math.PI * 2);
                ctx.strokeStyle = `rgba(82, 183, 136, ${Math.max(0, this.alpha * 0.5)})`;
                ctx.lineWidth = 2;
                ctx.stroke();
            }
        }

        // 2. 클릭 퐁당(Ripple) 클래스 정의
        class ClickRipple {
            constructor(x, y) {
                this.x = x;
                this.y = y;
                this.radius = 0;
                this.maxRadius = Math.max(canvas.width, canvas.height) * 0.4;
                this.alpha = 0.8;
                this.speed = 8;
            }
            update() {
                this.radius += this.speed;
                this.alpha = 0.8 * (1 - this.radius / this.maxRadius);
            }
            draw() {
                if (this.alpha <= 0) return;
                
                // 파원 중심원
                ctx.beginPath();
                ctx.arc(this.x, this.y, this.radius, 0, Math.PI * 2);
                ctx.strokeStyle = `rgba(216, 243, 220, ${this.alpha})`;
                ctx.lineWidth = 4;
                ctx.stroke();

                // 잔상 외부원
                ctx.beginPath();
                ctx.arc(this.x, this.y, this.radius * 0.8, 0, Math.PI * 2);
                ctx.strokeStyle = `rgba(82, 183, 136, ${this.alpha * 0.5})`;
                ctx.lineWidth = 2;
                ctx.stroke();
            }
        }

        // 마우스 및 터치 이벤트 리스너 등록
        window.addEventListener('mousemove', (e) => {
            pointer.x = e.clientX;
            pointer.y = e.clientY;
            pointer.isHovering = true;

            if (Math.random() < 0.3) { 
                waves.push(new HoverWave(pointer.x, pointer.y));
            }
        });

        window.addEventListener('mouseleave', () => {
            pointer.isHovering = false;
        });

        window.addEventListener('click', (e) => {
            ripples.push(new ClickRipple(e.clientX, e.clientY));
        });

        // 모바일 터치 이벤트 대응
        window.addEventListener('touchmove', (e) => {
            if(e.touches.length > 0) {
                pointer.x = e.touches[0].clientX;
                pointer.y = e.touches[0].clientY;
                if (Math.random() < 0.3) {
                    waves.push(new HoverWave(pointer.x, pointer.y));
                }
            }
        }, { passive: true });

        window.addEventListener('touchstart', (e) => {
            if(e.touches.length > 0) {
                ripples.push(new ClickRipple(e.touches[0].clientX, e.touches[0].clientY));
            }
        }, { passive: true });

        // 메인 애니메이션 루프
        function animate() {
            // 배경색 채우기 및 잔상 효과
            ctx.fillStyle = 'rgba(27, 67, 50, 0.08)'; 
            ctx.fillRect(0, 0, canvas.width, canvas.height);

            // 호버 파동 업데이트 및 그리기
            for (let i = waves.length - 1; i >= 0; i--) {
                waves[i].update();
                waves[i].draw();
                if (waves[i].radius >= waves[i].maxRadius || waves[i].alpha <= 0) {
                    waves.splice(i, 1);
                }
            }

            // 클릭 퐁당 업데이트 및 그리기
            for (let i = ripples.length - 1; i >= 0; i--) {
                ripples[i].update();
                ripples[i].draw();
                if (ripples[i].radius >= ripples[i].maxRadius || ripples[i].alpha <= 0) {
                    ripples.splice(i, 1);
                }
            }

            requestAnimationFrame(animate);
        }

        animate();
    </script>
</body>
</html>